# ============================================================
# quote-api 环境变量示例（本地开发 / Render 生产）
# 复制为 .env 仅作备忘；Spring Boot 实际读取系统环境变量或 Render Dashboard 配置
# ============================================================

# ---------- 通用 ----------
SPRING_PROFILES_ACTIVE=local
# Render 免费实例由平台注入，本地默认 8080
PORT=8080

# ---------- Render PostgreSQL（关联数据库后自动注入，无需手写）----------
# PGHOST=
# PGPORT=5432
# PGUSER=
# PGPASSWORD=
# PGDATABASE=furuiduo_quote
# DATABASE_URL=postgresql://...

# ---------- CORS（生产必改：填入 Vercel 前端域名）----------
# 多个域名用英文逗号分隔，支持通配符
CORS_ALLOWED_ORIGIN_PATTERNS=https://your-app.vercel.app,https://*.vercel.app,http://localhost:*

# ---------- 本地 MySQL（profile=mysql 时使用）----------
# SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/furuiduo_quote?useSSL=false&serverTimezone=Asia/Shanghai&characterEncoding=utf8
# SPRING_DATASOURCE_USERNAME=root
# SPRING_DATASOURCE_PASSWORD=123456
